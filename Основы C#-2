using System;

class Program
{
    static void Main()
    {
        //1
        Console.WriteLine("Квадраты в прямоугольнике");
        Console.Write("Введите A: ");
        int A = int.Parse(Console.ReadLine());

        Console.Write("Введите B: ");
        int B = int.Parse(Console.ReadLine());

        Console.Write("Введите C: ");
        int C = int.Parse(Console.ReadLine());

        if (C > A || C > B)
        {
            Console.WriteLine("Нельзя разместить ни одного квадрата");
        }
        else
        {
            int countA = A / C;
            int countB = B / C;
            int total = countA * countB;

            int rectArea = A * B;
            int squareArea = total * C * C;
            int freeArea = rectArea - squareArea;

            Console.WriteLine("Количество квадратов: " + total);
            Console.WriteLine("Незанятая площадь: " + freeArea);
        }

        Console.WriteLine();

        //2
        Console.WriteLine("Вклад");
        double S = 10000;
        Console.Write("Введите процент P: ");
        double P = double.Parse(Console.ReadLine());

        int months = 0;

        while (S <= 11000)
        {
            S = S + S * P / 100;
            months++;
        }

        Console.WriteLine("Месяцев: " + months);
        Console.WriteLine("Итоговая сумма: " + S);

        Console.WriteLine();

        // 3
        Console.WriteLine("Вывод чисел");
        Console.Write("Введите A: ");
        int a = int.Parse(Console.ReadLine());

        Console.Write("Введите B: ");
        int b = int.Parse(Console.ReadLine());

        for (int i = a; i <= b; i++)
        {
            for (int j = 0; j < i; j++)
            {
                Console.Write(i + " ");
            }
            Console.WriteLine();
        }

        Console.WriteLine();

        //4
        Console.WriteLine("(Переворот числа");
        Console.Write("Введите число: ");
        int N = int.Parse(Console.ReadLine());

        int reversed = 0;

        while (N > 0)
        {
            int digit = N % 10;
            reversed = reversed * 10 + digit;
            N = N / 10;
        }

        Console.WriteLine("Результат: " + reversed);
    }
}
