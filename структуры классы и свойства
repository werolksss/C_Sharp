using System;

// 5
enum ArticleType
{
    Еда,
    Одежда,
    Техника,
    Игрушки
}
//6
enum ClientType
{
    Обычный,
    Постоянный,
    VIP
}
//7
enum PayType
{
    Наличные,
    Карта,
    Онлайн
}
//Article
struct Article
{
    public int Code;
    public string Name;
    public double Price;
    public ArticleType Type;
}
// Client
struct Client
{
    public int Code;
    public string FullName;
    public string Address;
    public string Phone;
    public int OrdersCount;
    public double TotalOrdersSum;
    public ClientType Type;
}
// RequestItem
struct RequestItem
{
    public Article Product;
    public int Count;
}
// 4
struct Request
{
    public int RequestCode;
    public Client Client;
    public string Date;
    public RequestItem[] Items;
    public PayType Pay;
    // вычисляемое свойство
    public double TotalSum
    {
        get
        {
            double sum = 0;

            for (int i = 0; i < Items.Length; i++)
            {
                sum += Items[i].Product.Price * Items[i].Count;
            }

            return sum;
        }
    }
}
//8
class Student
{
    public string LastName;
    public string FirstName;
    public string MiddleName;
    public string Group;
    public int Age;
    // зубчатый массив
    public int[][] Marks;

    public Student(string lastName, string firstName,
        string middleName, string group, int age)
    {
        LastName = lastName;
        FirstName = firstName;
        MiddleName = middleName;
        Group = group;
        Age = age;
        // 0 - программирование
        // 1 - администрирование
        // 2 - дизайн
        Marks = new int[3][];
        Marks[0] = new int[3];
        Marks[1] = new int[3];
        Marks[2] = new int[3];
    }

    // установка оценки
    public void SetMark(int subject, int index, int mark)
    {
        Marks[subject][index] = mark;
    }
    // получение оценки
    public int GetMark(int subject, int index)
    {
        return Marks[subject][index];
    }
    // средний балл
    public double GetAverage(int subject)
    {
        int sum = 0;

        for (int i = 0; i < Marks[subject].Length; i++)
        {
            sum += Marks[subject][i];
        }

        return (double)sum / Marks[subject].Length;
    }
    // вывод информации
    public void ShowInfo()
    {
        Console.WriteLine("ФИО: " +
            LastName + " " +
            FirstName + " " +
            MiddleName);

        Console.WriteLine("Группа: " + Group);
        Console.WriteLine("Возраст: " + Age);

        Console.WriteLine("Средний балл по программированию: " +
            GetAverage(0));

        Console.WriteLine("Средний балл по администрированию: " +
            GetAverage(1));

        Console.WriteLine("Средний балл по дизайну: " +
            GetAverage(2));
    }
}

