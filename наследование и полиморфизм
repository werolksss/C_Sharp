class Passport
{
    public string FullName;
    public string Country;
    public string PassportNumber;

    public Passport(string fullName, string country, string passportNumber)
    {
        FullName = fullName;
        Country = country;
        PassportNumber = passportNumber;
    }

    public virtual void ShowPassport()
    {
        Console.WriteLine("ФИО: " + FullName);
        Console.WriteLine("Страна: " + Country);
        Console.WriteLine("Номер паспорта: " + PassportNumber);
    }
}

class ForeignPassport : Passport
{
    public string ForeignNumber;
    public string Visa;

    public ForeignPassport(string fullName, string country,
        string passportNumber, string foreignNumber, string visa)
        : base(fullName, country, passportNumber)
    {
        ForeignNumber = foreignNumber;
        Visa = visa;
    }

    public override void ShowPassport()
    {
        Console.WriteLine("Загранпаспорт");
        base.ShowPassport();
        Console.WriteLine("Номер загранпаспорта: " + ForeignNumber);
        Console.WriteLine("Виза: " + Visa);
    }
}

