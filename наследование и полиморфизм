using System;

//1

class Human
{
    public string Name;
    public int Age;

    public Human(string name, int age)
    {
        Name = name;
        Age = age;
    }

    public virtual void ShowInfo()
    {
        Console.WriteLine("Имя: " + Name);
        Console.WriteLine("Возраст: " + Age);
    }
}

class Builder : Human
{
    public string Company;

    public Builder(string name, int age, string company)
        : base(name, age)
    {
        Company = company;
    }

    public override void ShowInfo()
    {
        Console.WriteLine("Строитель");
        base.ShowInfo();
        Console.WriteLine("Компания: " + Company);
    }
}

class Sailor : Human
{
    public string Ship;

    public Sailor(string name, int age, string ship)
        : base(name, age)
    {
        Ship = ship;
    }

    public override void ShowInfo()
    {
        Console.WriteLine("Моряк");
        base.ShowInfo();
        Console.WriteLine("Корабль: " + Ship);
    }
}

class Pilot : Human
{
    public string Plane;

    public Pilot(string name, int age, string plane)
        : base(name, age)
    {
        Plane = plane;
    }

    public override void ShowInfo()
    {
        Console.WriteLine("Летчик");
        base.ShowInfo();
        Console.WriteLine("Самолет: " + Plane);
    }
}

